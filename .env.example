# Arinova Chat connection (default: wss://api.chat.arinova.ai)
# ARINOVA_SERVER_URL=ws://localhost:3501
ARINOVA_BOT_TOKEN=your-bot-token-here

# Default provider ID (must match an id in config.json providers array)
DEFAULT_PROVIDER=anthropic-oauth

# API Keys (configured per-provider in config.json, env vars override for testing)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MINIMAX_API_KEY=

# CLI paths
CLAUDE_PATH=claude
CODEX_BINARY_PATH=

# Defaults
DEFAULT_CWD=~/projects
MAX_SESSIONS=5
DB_PATH=~/.arinova-bridge/bridge.db
MCP_CONFIG_PATH=
