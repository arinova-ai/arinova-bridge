# Arinova Chat connection
ARINOVA_SERVER_URL=ws://localhost:3501
ARINOVA_BOT_TOKEN=your-bot-token-here

# Default provider (anthropic-api | anthropic-oauth | openai-api | openai-oauth)
DEFAULT_PROVIDER=anthropic-oauth

# Anthropic API (for anthropic-api provider)
ANTHROPIC_API_KEY=

# Claude CLI path (for anthropic-oauth provider)
CLAUDE_PATH=claude

# OpenAI API (for openai-api provider)
OPENAI_API_KEY=

# Codex CLI path (for openai-api / openai-oauth providers)
CODEX_BINARY_PATH=

# Defaults
DEFAULT_CWD=~/projects
MAX_SESSIONS=5
DB_PATH=~/.arinova-bridge/bridge.db
MCP_CONFIG_PATH=
