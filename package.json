{
  "name": "@arinova-ai/arinova-bridge",
  "version": "0.0.1",
  "description": "Multi-provider bridge between Arinova Chat and AI coding assistants (Claude, Codex)",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    ".env.example"
  ],
  "bin": {
    "arinova-bridge": "dist/index.js",
    "arinova-bridge-setup": "dist/setup.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "setup": "tsx src/setup.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^1.0.0",
    "@arinova-ai/agent-sdk": "^0.0.15",
    "@inquirer/prompts": "^8.2.1",
    "better-sqlite3": "^11.0.0",
    "node-pty": "^1.2.0-beta.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^25.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
